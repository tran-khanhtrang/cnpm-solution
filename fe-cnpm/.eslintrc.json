{
    "extends": [
        "react-app",
        "react-app/jest"
    ],
    "plugins": [
        "unused-imports"
    ],
    "rules": {
        "no-unused-vars": "off",
        "unused-imports/no-unused-imports": "warn",
        "unused-imports/no-unused-vars": "off",
        "react-hooks/exhaustive-deps": "off",
        "jsx-a11y/alt-text": "off",
        "eqeqeq": "off",
        "array-callback-return": "off"
    }
}